rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /logos/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == orgId;
    }
    match /events/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == orgId;
    }
    match /qr/{allPaths=**} {
      allow read: if true;
      allow write: if false; // solo admin SDK
    }
  }
}
